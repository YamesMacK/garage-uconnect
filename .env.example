# Mopar credentials — same email/password you use for connect.ramtrucks.com
# and the Ram/Jeep mobile apps.
#
# NOTE: nothing auto-loads this file (no python-dotenv). Set these as real
# env vars in your shell for local runs, or as GitHub Actions secrets for CI:
#   PowerShell:  $env:MOPAR_EMAIL = "you@example.com"  (etc.)
MOPAR_EMAIL=you@example.com
MOPAR_PASSWORD=your_mopar_password
MOPAR_PIN=1234
